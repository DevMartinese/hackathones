---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Enviar Hackathon | Hackathons Argentina" description="Sugerir un hackathon para agregar al listado.">
  <header class="header">
    <p class="prompt">
      <span class="typed">$ hackathons-ar --submit</span><span class="cursor"></span>
    </p>
    <br />
    <p class="title">Enviar un hackathon</p>
    <p class="meta">Completa los campos y lo revisamos para agregarlo al listado.</p>
  </header>

  <form id="submit-form" class="form">
    <div class="field">
      <label for="name">nombre *</label>
      <input type="text" id="name" name="name" required placeholder="HackIT BA 2026" />
    </div>

    <div class="row">
      <div class="field">
        <label for="date_start">fecha inicio *</label>
        <input type="date" id="date_start" name="date_start" required />
      </div>
      <div class="field">
        <label for="date_end">fecha fin</label>
        <input type="date" id="date_end" name="date_end" />
      </div>
    </div>

    <div class="row">
      <div class="field">
        <label for="country">pais</label>
        <select id="country" name="country">
          <option value="">--</option>
          <option value="Global">Global</option>
          <option value="Argentina">Argentina</option>
          <option value="Brasil">Brasil</option>
          <option value="Chile">Chile</option>
          <option value="Colombia">Colombia</option>
          <option value="Mexico">Mexico</option>
          <option value="Peru">Peru</option>
          <option value="Uruguay">Uruguay</option>
          <option value="Paraguay">Paraguay</option>
          <option value="Ecuador">Ecuador</option>
          <option value="Bolivia">Bolivia</option>
          <option value="Venezuela">Venezuela</option>
          <option value="Costa Rica">Costa Rica</option>
          <option value="Panama">Panama</option>
          <option value="Guatemala">Guatemala</option>
          <option value="USA">USA</option>
          <option value="Canada">Canada</option>
        </select>
      </div>
      <div class="field">
        <label for="type">tipo</label>
        <select id="type" name="type">
          <option value="">--</option>
          <option value="presencial">presencial</option>
          <option value="online">online</option>
          <option value="hibrido">hibrido</option>
        </select>
      </div>
    </div>

    <div class="field" id="city-field">
      <label for="city">ciudad</label>
      <input type="text" id="city" name="city" placeholder="Buenos Aires" />
    </div>

    <div class="field">
      <label for="location">lugar</label>
      <input type="text" id="location" name="location" placeholder="Centro Cultural Kirchner" />
    </div>

    <div class="field">
      <label for="url">url del evento *</label>
      <input type="url" id="url" name="url" required placeholder="https://..." />
    </div>

    <div class="field">
      <label for="tags">tags (separados por coma)</label>
      <input type="text" id="tags" name="tags" placeholder="AI, web3, fintech" />
    </div>

    <div class="field">
      <label for="description">descripcion</label>
      <textarea id="description" name="description" rows="3" placeholder="Breve descripcion del evento..."></textarea>
    </div>

    <div class="actions">
      <button type="submit" class="submit-btn">$ submit --hackathon</button>
      <a href="/" class="back">$ cd ..</a>
    </div>

    <p class="success" id="success-msg" style="display: none;">
      > issue creado. lo revisamos pronto. gracias!
    </p>
  </form>
</BaseLayout>

<script>
  const form = document.getElementById("submit-form") as HTMLFormElement;
  const successMsg = document.getElementById("success-msg") as HTMLElement;
  const countrySelect = document.getElementById("country") as HTMLSelectElement;
  const cityField = document.getElementById("city-field") as HTMLElement;

  countrySelect.addEventListener("change", () => {
    if (countrySelect.value === "Global") {
      cityField.style.display = "none";
      (cityField.querySelector("input") as HTMLInputElement).value = "";
    } else {
      cityField.style.display = "";
    }
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const name = data.get("name") as string;
    const dateStart = data.get("date_start") as string;
    const dateEnd = data.get("date_end") as string;
    const country = data.get("country") as string;
    const city = data.get("city") as string;
    const type = data.get("type") as string;
    const location = data.get("location") as string;
    const url = data.get("url") as string;
    const tags = data.get("tags") as string;
    const description = data.get("description") as string;

    const body = [
      `## ${name}`,
      "",
      `- **Fecha**: ${dateStart}${dateEnd ? ` - ${dateEnd}` : ""}`,
      country ? `- **Pais**: ${country}` : "",
      city ? `- **Ciudad**: ${city}` : "",
      type ? `- **Tipo**: ${type}` : "",
      location ? `- **Lugar**: ${location}` : "",
      `- **URL**: ${url}`,
      tags ? `- **Tags**: ${tags}` : "",
      "",
      description ? `### Descripcion\n${description}` : "",
    ]
      .filter(Boolean)
      .join("\n");

    const issueTitle = encodeURIComponent(`[hackathon] ${name}`);
    const issueBody = encodeURIComponent(body);
    const issueUrl = `https://github.com/ainponce/hackathons-ar/issues/new?title=${issueTitle}&body=${issueBody}&labels=hackathon-submission`;

    window.open(issueUrl, "_blank");

    successMsg.style.display = "";
    form.reset();
  });
</script>

<style>
  .header {
    margin-bottom: 2rem;
  }

  .prompt {
    font-weight: 700;
    overflow: hidden;
    white-space: nowrap;
  }

  .typed {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    animation: typewriter 0.6s steps(24) 0.2s forwards;
  }

  .cursor::after {
    content: "\2588";
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  .title {
    animation: fadeUp 0.5s ease 0.7s both;
  }

  .meta {
    color: var(--muted);
    font-size: var(--font-size-sm);
    animation: fadeUp 0.5s ease 0.9s both;
  }

  .form {
    animation: fadeUp 0.5s ease 1s both;
  }

  .field {
    margin-bottom: 1rem;
  }

  .row {
    display: flex;
    gap: 1rem;
  }

  .row .field {
    flex: 1;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: var(--font-size-sm);
    margin-bottom: 0.2rem;
  }

  input,
  textarea,
  select {
    font-family: var(--font-mono);
    font-size: var(--font-size-base);
    background: var(--bg);
    color: var(--text);
    border: none;
    border-bottom: 1px solid #ddd;
    width: 100%;
    padding: 0.3rem 0;
    outline: none;
    transition: border-color 0.2s ease;
  }

  input:focus,
  textarea:focus,
  select:focus {
    border-bottom-color: var(--text);
  }

  input::placeholder,
  textarea::placeholder {
    color: #ccc;
  }

  textarea {
    resize: vertical;
    min-height: 3rem;
  }

  select {
    cursor: pointer;
  }

  .actions {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-top: 1.5rem;
  }

  .submit-btn {
    font-family: var(--font-mono);
    font-size: var(--font-size-base);
    font-weight: 700;
    background: var(--text);
    color: var(--bg);
    border: none;
    padding: 0.4rem 1rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .submit-btn:hover {
    opacity: 0.7;
  }

  .back {
    color: var(--muted);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .back:hover {
    color: var(--text);
  }

  .success {
    margin-top: 1rem;
    font-weight: 700;
    animation: fadeUp 0.3s ease both;
  }

  @media (max-width: 600px) {
    .row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
