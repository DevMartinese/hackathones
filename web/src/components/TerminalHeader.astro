---
interface Props {
  count?: number;
  lastUpdated?: string;
}

const { count = 0, lastUpdated } = Astro.props;
const dateStr = lastUpdated || new Date().toISOString().split("T")[0];
---

<header class="header">
  <p class="prompt">
    <span class="typed">$ hackathons-ar --list --upcoming</span><span class="cursor"></span>
  </p>
  <br />
  <p class="title">Hackathons en Argentina</p>
  <p class="meta">{count} eventos encontrados | actualizado: {dateStr}</p>
  <p class="meta">fuentes: x/twitter, lu.ma</p>
</header>

<style>
  .header {
    margin-bottom: 2rem;
  }

  .prompt {
    font-weight: 700;
    overflow: hidden;
    white-space: nowrap;
  }

  .typed {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    animation: typewriter 0.8s steps(32) 0.2s forwards;
  }

  .cursor::after {
    content: "\2588";
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  .title {
    animation: fadeUp 0.5s ease 0.9s both;
  }

  .meta {
    color: var(--muted);
    font-size: var(--font-size-sm);
    animation: fadeUp 0.5s ease 1.1s both;
  }

  .meta:last-child {
    animation-delay: 1.2s;
  }
</style>
