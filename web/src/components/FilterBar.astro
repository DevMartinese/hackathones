---
interface Props {
  cities: string[];
  types: string[];
  tags: string[];
}

const { cities, types, tags } = Astro.props;
---

<div class="filters">
  <p class="prompt">$ hackathons-ar --filter</p>
  <div class="controls">
    <label>
      --ciudad
      <select id="filter-city">
        <option value="">*</option>
        {cities.map((city) => (
          <option value={city.toLowerCase()}>{city.toLowerCase()}</option>
        ))}
      </select>
    </label>

    <label>
      --tipo
      <select id="filter-type">
        <option value="">*</option>
        {types.map((type) => (
          <option value={type}>{type}</option>
        ))}
      </select>
    </label>

    <label>
      --tag
      <select id="filter-tag">
        <option value="">*</option>
        {tags.map((tag) => (
          <option value={tag.toLowerCase()}>{tag.toLowerCase()}</option>
        ))}
      </select>
    </label>

    <button id="filter-reset" type="button">--reset</button>
  </div>
</div>

<script>
  function initFilters() {
    const citySelect = document.getElementById("filter-city") as HTMLSelectElement;
    const typeSelect = document.getElementById("filter-type") as HTMLSelectElement;
    const tagSelect = document.getElementById("filter-tag") as HTMLSelectElement;
    const resetBtn = document.getElementById("filter-reset") as HTMLButtonElement;
    const visibleCount = document.getElementById("visible-count") as HTMLSpanElement;
    const emptyState = document.getElementById("empty-state") as HTMLElement;
    const cards = document.querySelectorAll<HTMLElement>(".card");

    function applyFilters() {
      const city = citySelect.value;
      const type = typeSelect.value;
      const tag = tagSelect.value;
      let visible = 0;

      cards.forEach((card) => {
        const cardCity = card.dataset.city || "";
        const cardType = card.dataset.type || "";
        const cardTags = card.dataset.tags || "";

        const matchCity = !city || cardCity === city;
        const matchType = !type || cardType === type;
        const matchTag = !tag || cardTags.split(",").includes(tag);

        if (matchCity && matchType && matchTag) {
          card.style.display = "";
          visible++;
        } else {
          card.style.display = "none";
        }
      });

      visibleCount.textContent = String(visible);
      emptyState.style.display = visible === 0 ? "" : "none";
    }

    citySelect.addEventListener("change", applyFilters);
    typeSelect.addEventListener("change", applyFilters);
    tagSelect.addEventListener("change", applyFilters);
    resetBtn.addEventListener("click", () => {
      citySelect.value = "";
      typeSelect.value = "";
      tagSelect.value = "";
      applyFilters();
    });
  }

  initFilters();
</script>

<style>
  .filters {
    margin-bottom: 2rem;
    animation: fadeUp 0.5s ease 1.3s both;
  }

  .prompt {
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .controls {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: var(--font-size-sm);
  }

  label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--muted);
  }

  select {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    background: var(--bg);
    color: var(--text);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  select:focus {
    outline: none;
  }

  button {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    background: none;
    color: var(--muted);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s ease;
  }

  button:hover {
    color: var(--text);
  }

  @media (max-width: 600px) {
    .controls {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
