---
import HackathonCard from "./HackathonCard.astro";

interface Props {
  hackathons: Array<{
    data: {
      name: string;
      date_start: string | null;
      date_end: string | null;
      city: string | null;
      location: string | null;
      url: string | null;
      source: "x" | "luma";
      type: "presencial" | "online" | "hibrido" | null;
      tags: string[];
      description: string;
    };
  }>;
}

const { hackathons } = Astro.props;
---

<section id="hackathon-list">
  <p class="counter">
    Mostrando <span id="visible-count">{hackathons.length}</span> de {hackathons.length} hackathones
  </p>

  <div class="items" id="list-items">
    {hackathons.map((h) => (
      <HackathonCard {...h.data} />
    ))}
  </div>

  <p class="empty" id="empty-state" style="display: none;">
    No se encontraron hackathones con esos filtros.
  </p>
</section>

<style>
  .items :global(article) {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .items :global(article:last-child) {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .counter {
    color: var(--muted);
    font-size: var(--font-size-sm);
    margin-bottom: 1.5rem;
  }

  .empty {
    color: var(--muted);
    font-size: var(--font-size-sm);
    padding: 2rem 0;
  }
</style>
