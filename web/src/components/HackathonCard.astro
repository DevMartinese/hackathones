---
interface Props {
  name: string;
  date_start: string | null;
  date_end: string | null;
  city: string | null;
  location: string | null;
  url: string | null;
  source: "x" | "luma";
  type: "presencial" | "online" | "hibrido" | null;
  tags: string[];
  description: string;
  index?: number;
}

const { name, date_start, date_end, city, location, url, source, type, tags, description, index = 0 } = Astro.props;

function formatDate(start: string | null, end: string | null): string {
  if (!start) return "fecha a confirmar";
  const opts: Intl.DateTimeFormatOptions = { day: "numeric", month: "short" };
  const s = new Date(start + "T00:00:00");
  const startStr = s.toLocaleDateString("es-AR", opts);
  if (!end || start === end) return startStr;
  const e = new Date(end + "T00:00:00");
  const endStr = e.toLocaleDateString("es-AR", opts);
  return `${startStr} - ${endStr}`;
}

const meta = [
  formatDate(date_start, date_end),
  city,
  type,
  `via ${source}`,
].filter(Boolean).join("  /  ");
---

<article
  class="card fade-in"
  data-city={city?.toLowerCase() || ""}
  data-type={type || ""}
  data-tags={tags.map((t) => t.toLowerCase()).join(",")}
  style={`transition-delay: ${index * 0.06}s`}
>
  <p class="name">> {name}</p>
  <p class="meta">{meta}</p>
  {location && <p class="meta">{location}</p>}
  {tags.length > 0 && <p class="tags">{tags.map((t) => `[${t}]`).join(" ")}</p>}
  <p class="desc">{description}</p>
  {url && <p><a href={url} target="_blank" rel="noopener noreferrer">{url}</a></p>}
</article>

<style>
  .card {
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .name {
    font-weight: 700;
  }

  .meta {
    color: var(--muted);
    font-size: var(--font-size-sm);
  }

  .tags {
    font-size: var(--font-size-sm);
    color: var(--muted);
  }

  .desc {
    font-size: var(--font-size-sm);
    margin-top: 0.25rem;
  }

  a {
    font-size: var(--font-size-sm);
  }
</style>
