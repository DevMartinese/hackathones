---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p class="meta">Hecho en Argentina | {year}</p>
  <p class="meta">
    <a href="/submit">$ hackathons-ar --submit</a>
    &nbsp;&nbsp;
    <a href="https://github.com/ainponce/hackathones" target="_blank" rel="noopener noreferrer"
      >github.com/ainponce/hackathones</a
    >
  </p>
</footer>

<style>
  .footer {
    margin-top: 3rem;
    padding-top: 1rem;
    animation: fadeIn 0.5s ease 1.8s both;
  }

  .meta {
    color: var(--muted);
    font-size: var(--font-size-sm);
  }

  .meta a {
    color: var(--muted);
    transition: color 0.2s ease;
  }

  .meta a:hover {
    color: var(--text);
  }
</style>
