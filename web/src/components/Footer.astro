---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p class="meta">Hecho en Argentina | {year}</p>
  <p class="meta links">
    <a href="/submit">$ hackathons-ar --submit</a>
    <a href="https://github.com/ainponce/hackathones" target="_blank" rel="noopener noreferrer"
      >github.com/ainponce/hackathones</a
    >
  </p>
</footer>

<style>
  .footer {
    margin-top: 3rem;
    padding-top: 1rem;
    animation: fadeIn 0.5s ease 1.8s both;
  }

  .meta {
    color: var(--muted);
    font-size: var(--font-size-sm);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 1rem;
  }

  .meta a {
    color: var(--muted);
    transition: color 0.2s ease;
  }

  .meta a:hover {
    color: var(--text);
  }
</style>
