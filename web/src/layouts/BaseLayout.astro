---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hackathones - Directorio de hackathones en America",
  description = "Directorio de hackathones en America. Terminal interactiva para buscar y enviar hackathones.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script is:inline>
      // Prevent flash of terminal under the intro loader on home.
      try {
        var p = location.pathname;
        if (p === "/" || p === "") {
          document.documentElement.classList.add("intro-pending");
        }
      } catch (e) {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://hackathones.com" />
    <meta property="og:image" content="https://hackathones.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://hackathones.com/og-image.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/variables.css";
  @import "../styles/global.css";
</style>
